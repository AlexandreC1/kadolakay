# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon or local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kadolakay

# Auth.js
AUTH_SECRET= # Generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (email magic links)
AUTH_RESEND_KEY=
AUTH_RESEND_FROM="KadoLakay <noreply@kadolakay.com>"

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox # sandbox or live

# MonCash (Digicel)
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox # sandbox or live

# Natcash
NATCASH_MERCHANT_NUMBER=

# S3-compatible storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=kadolakay
S3_REGION=auto
S3_PUBLIC_URL= # e.g., https://cdn.kadolakay.com
